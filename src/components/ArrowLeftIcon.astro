---
/**
 * Heroicons outline "arrow-left" (MIT) — https://heroicons.com
 * Stroke weight aligned with theme toggle icons on the site.
 */
interface Props {
	class?: string;
}

const { class: className } = Astro.props;
---

<svg
	class={className}
	xmlns="http://www.w3.org/2000/svg"
	viewBox="0 0 24 24"
	fill="none"
	stroke="currentColor"
	stroke-width="2"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	focusable="false"
>
	<path
		d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"
	></path>
</svg>
