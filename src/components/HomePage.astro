---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCase from './ProjectCase.astro';
import SmallTool from './SmallTool.astro';
import { getPrimaryProjects, getSecondaryProjects } from '../data/projects';
import { site } from '../data/site';
import type { Locale } from '../i18n/config';
import { getMessages } from '../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getMessages(locale);
const canonicalPath = locale === 'es' ? '/es/' : '/';
const base = import.meta.env.BASE_URL;
const hrefEn = base.endsWith('/') ? base : `${base}/`;
const hrefEs = `${hrefEn}es/`;

const gmailComposeUrl = `https://mail.google.com/mail/?view=cm&fs=1&to=${encodeURIComponent(site.email)}`;
const primaryProjects = getPrimaryProjects(locale);
const secondaryProjects = getSecondaryProjects(locale);

const alternates = [
	{ hreflang: 'en', href: new URL('/', site.url).href },
	{ hreflang: 'es', href: new URL('/es/', site.url).href },
	{ hreflang: 'x-default', href: new URL('/', site.url).href },
];

const localeBundleJson = JSON.stringify({
	baseUrl: import.meta.env.BASE_URL,
	siteUrl: site.url,
	messages: { en: getMessages('en'), es: getMessages('es') },
	projects: {
		en: {
			primary: getPrimaryProjects('en'),
			secondary: getSecondaryProjects('en'),
		},
		es: {
			primary: getPrimaryProjects('es'),
			secondary: getSecondaryProjects('es'),
		},
	},
}).replace(/</g, '\\u003c');
---

<BaseLayout
	title={t.meta.title}
	description={t.meta.description}
	canonicalPath={canonicalPath}
	lang={locale}
	skipToContent={t.a11y.skipToContent}
	alternates={alternates}
	localeBundleJson={localeBundleJson}
>
	<div class="page">
		<aside class="site-sidebar" aria-label={t.a11y.siteAside}>
			<div class="site-sidebar__inner">
				<nav class="nav" aria-label={t.nav.ariaLabel}>
					<a href="#intro-heading" data-i18n="nav.intro">{t.nav.intro}</a>
					<a href="#skills-heading" data-i18n="nav.skills">{t.nav.skills}</a>
					<a href="#projects-heading" data-i18n="nav.projects">{t.nav.projects}</a>
					<a href="#cv-heading" data-i18n="nav.cvFile">{t.nav.cvFile}</a>
					<a href="#contact-heading" data-i18n="nav.contact">{t.nav.contact}</a>
					<a href={site.github} target="_blank" rel="noopener noreferrer" data-i18n="nav.github"
						>{t.nav.github}</a
					>
				</nav>
				<nav class="lang-switcher" aria-label={t.language.ariaLabel}>
					<a
						class="lang-switcher__link"
						href={hrefEn}
						hreflang="en"
						lang="en"
						data-i18n="language.english"
						data-locale-target="en"
						aria-current={locale === 'en' ? 'page' : undefined}
					>
						{t.language.english}
					</a>
					<span class="lang-switcher__sep" aria-hidden="true">·</span>
					<a
						class="lang-switcher__link"
						href={hrefEs}
						hreflang="es"
						lang="es"
						data-i18n="language.spanish"
						data-locale-target="es"
						aria-current={locale === 'es' ? 'page' : undefined}
					>
						{t.language.spanish}
					</a>
				</nav>
			</div>
		</aside>

		<main id="main" class="site-main">
			<div class="site-main__inner">
				<section id="intro" class="section" aria-labelledby="intro-heading">
					<h1 id="intro-heading" class="intro__title">{site.name}</h1>
					<p class="identity__meta intro__subtitle">
						<span class="identity__role" data-i18n="identity.headline">{t.identity.headline}</span>
						<span class="identity__location">
							<span data-i18n="identity.location">{t.identity.location}</span>
							{site.openToRelocation ? (
								<>
									<span class="identity__sep" aria-hidden="true">
										{'\u00a0·\u00a0'}
									</span>
									<span data-i18n="identity.openToRelocation">{t.identity.openToRelocation}</span>
								</>
							) : null}
						</span>
					</p>
					<p class="intro__lead" data-i18n="profileLead">{t.profileLead}</p>
				</section>

				<section id="skills" class="section" aria-labelledby="skills-heading">
					<h2 id="skills-heading" data-i18n="sections.skills.title">{t.sections.skills.title}</h2>
					<p class="section__intro" data-i18n="sections.skills.intro">{t.sections.skills.intro}</p>
					<ul class="skills">
						{t.technicalSkills.map((line) => (
							<li>{line}</li>
						))}
					</ul>
				</section>

				<section id="projects" class="section" aria-labelledby="projects-heading">
					<h2 id="projects-heading" data-i18n="sections.projects.title">
						{t.sections.projects.title}
					</h2>
					<p class="section__intro" data-i18n="sections.projects.intro">
						{t.sections.projects.intro}
					</p>
					{primaryProjects.map((project) => (
						<ProjectCase project={project} githubCta={t.sections.projects.githubCta} />
					))}
					<h3 id="smaller-tools-heading" class="section__subheading" data-i18n="sections.projects.smallerTools">
						{t.sections.projects.smallerTools}
					</h3>
					<div class="small-tools">
						{secondaryProjects.map((tool) => (
							<SmallTool tool={tool} githubCta={t.sections.projects.githubCtaSmall} />
						))}
					</div>
				</section>

				<section id="cv" class="section" aria-labelledby="cv-heading">
					<h2 id="cv-heading" data-i18n="sections.cv.title">{t.sections.cv.title}</h2>
					<div class="download-row">
						<a class="btn" href={`${import.meta.env.BASE_URL}resume/CV.md`} download data-i18n="sections.cv.downloadCv">
							{t.sections.cv.downloadCv}
						</a>
						<a
							class="btn btn--ghost"
							href={`${import.meta.env.BASE_URL}resume/CV.md`}
							data-i18n="sections.cv.viewCv"
						>
							{t.sections.cv.viewCv}
						</a>
						<a
							class="btn btn--ghost"
							href={site.cvRepo}
							target="_blank"
							rel="noopener noreferrer"
							data-i18n="sections.cv.cvRepo"
						>
							{t.sections.cv.cvRepo}
						</a>
					</div>
				</section>

				<section id="contact" class="section" aria-labelledby="contact-heading">
					<h2 id="contact-heading" data-i18n="sections.contact.title">{t.sections.contact.title}</h2>
					<p>
						<a href={gmailComposeUrl} target="_blank" rel="noopener noreferrer">{site.email}</a>
					</p>
				</section>
			</div>
		</main>
	</div>
</BaseLayout>
