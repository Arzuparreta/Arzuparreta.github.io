---
import type { PrimaryProject } from '../data/projects';

interface Props {
	project: PrimaryProject;
	githubCta: string;
}

const { project, githubCta } = Astro.props;
---

<article class="case" id={project.slug}>
	<header class="case__top">
		<h3 class="case__title">
			<a class="case__title-link" href={project.repoUrl} target="_blank" rel="noopener noreferrer">
				{project.title}
			</a>
			<span class="case__title-sep" aria-hidden="true"> | </span>
			<span class="case__tech">{project.tech}</span>
		</h3>
	</header>
	<p class="case__why">{project.why}</p>
	<ul class="case__how">
		{project.how.map((line) => (
			<li>{line}</li>
		))}
	</ul>
	<p class="case__cta">
		<a href={project.repoUrl} target="_blank" rel="noopener noreferrer">{githubCta}</a>
	</p>
</article>
