---
import type { Project } from '../data/projects';
import type { Messages } from '../i18n/types';

interface Props {
	project: Project;
	labels: Messages['projectCase'];
}

const { project, labels } = Astro.props;
---

<article class="case" id={project.slug}>
	<header class="case__top">
		<h3 class="case__title">
			<a href={project.repoUrl} target="_blank" rel="noopener noreferrer">{project.title}</a>
		</h3>
		<p class="case__tagline">{project.tagline}</p>
	</header>
	<div class="case__meta">
		<span>{project.languages.join(' · ')}</span>
	</div>
	<div class="case__actions">
		<a class="btn" href={project.repoUrl} target="_blank" rel="noopener noreferrer">{labels.github}</a>
		{
			project.liveUrl ? (
				<a class="btn btn--ghost" href={project.liveUrl} target="_blank" rel="noopener noreferrer">
					{labels.viewLive}
				</a>
			) : null
		}
	</div>
	<dl class="case__dl">
		<dt class="case__dt">{labels.stack}</dt>
		<dd class="case__dd"><p>{project.stack}</p></dd>
		<dt class="case__dt">{labels.architecture}</dt>
		<dd class="case__dd"><p>{project.architecture}</p></dd>
		<dt class="case__dt">{labels.keyFeature}</dt>
		<dd class="case__dd"><p>{project.keyFeature}</p></dd>
	</dl>
</article>
