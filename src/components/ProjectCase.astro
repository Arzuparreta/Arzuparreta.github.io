---
import type { Project } from '../data/projects';
import type { Messages } from '../i18n/types';

interface Props {
	project: Project;
	labels: Messages['projectCase'];
}

const { project, labels } = Astro.props;
---

<article class="case" id={project.slug}>
	<header class="case__top">
		<h3 class="case__title">
			<a href={project.repoUrl} target="_blank" rel="noopener noreferrer">{project.title}</a>
		</h3>
		<p class="case__tagline">{project.tagline}</p>
	</header>
	<div class="case__meta">
		<span>{project.languages.join(' · ')}</span>
		<a href={project.repoUrl} target="_blank" rel="noopener noreferrer">{labels.repository}</a>
	</div>
	<dl class="case__dl">
		<dt class="case__dt">{labels.problem}</dt>
		<dd class="case__dd"><p>{project.problem}</p></dd>
		<dt class="case__dt">{labels.approach}</dt>
		<dd class="case__dd"><p>{project.approach}</p></dd>
		<dt class="case__dt">{labels.stack}</dt>
		<dd class="case__dd"><p>{project.stack.join(' · ')}</p></dd>
		<dt class="case__dt">{labels.reflection}</dt>
		<dd class="case__dd"><p>{project.reflection}</p></dd>
	</dl>
</article>
