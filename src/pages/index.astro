---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCase from '../components/ProjectCase.astro';
import { projects } from '../data/projects';
import { site, philosophy, cvHighlights } from '../data/site';
---

<BaseLayout title={site.title} description={site.description} canonicalPath="/">
	<div class="page">
		<header class="site-header">
			<div class="site-header__inner">
				<div>
					<p class="identity__name">{site.name}</p>
					<p class="identity__meta">
						Developer · Musician · @{site.handle} · {site.location}
					</p>
				</div>
				<nav class="nav" aria-label="Primary">
					<a href="#intro">Intro</a>
					<a href="#projects">Projects</a>
					<a href="#work">How I work</a>
					<a href="#cv">CV</a>
					<a href="#contact">Contact</a>
					<a href={site.github} target="_blank" rel="noopener noreferrer">GitHub</a>
				</nav>
			</div>
		</header>

		<main id="main" class="site-main">
			<div class="site-main__inner">
				<section id="intro" class="section" aria-labelledby="intro-heading">
					<h1 id="intro-heading" class="intro__title">{site.name}</h1>
					<p class="intro__lead">
						Full-stack and systems-oriented development: JavaScript and Rust for shipped work, Python for
						exploration. Focus on self-hosted software, clear boundaries, and repositories you can audit.
					</p>
					<p class="intro__note">
						Below: concise case studies with links to public code—no decorative filler.
					</p>
				</section>

				<section id="projects" class="section" aria-labelledby="projects-heading">
					<h2 id="projects-heading">Projects</h2>
					<p class="section__intro">Each row links to a public repository on GitHub.</p>
					{projects.map((project) => <ProjectCase project={project} />)}
				</section>

				<section id="work" class="section" aria-labelledby="work-heading">
					<h2 id="work-heading">How I work</h2>
					<p class="section__intro">{philosophy.lede}</p>
					<ul class="principles">
						{philosophy.points.map((item) => (
							<li class="principles__item">
								<h3>{item.head}</h3>
								<p>{item.body}</p>
							</li>
						))}
					</ul>
				</section>

				<section id="cv" class="section" aria-labelledby="cv-heading">
					<h2 id="cv-heading">CV</h2>
					<p class="cv-summary">{cvHighlights.summary}</p>
					<h3 class="visually-hidden">Skills</h3>
					<ul class="skills">
						{cvHighlights.skills.map((line) => (
							<li>{line}</li>
						))}
					</ul>
					<div class="download-row">
						<a class="btn" href={`${import.meta.env.BASE_URL}resume/CV.md`} download>
							Download CV (.md)
						</a>
						<a class="btn btn--ghost" href={`${import.meta.env.BASE_URL}resume/CV.md`}>
							View Markdown
						</a>
					</div>
				</section>

				<section id="contact" class="section" aria-labelledby="contact-heading">
					<h2 id="contact-heading">Contact</h2>
					<p>
						Primary channel: <a href={site.github} target="_blank" rel="noopener noreferrer">GitHub</a>
						(issues, discussions, profile).
					</p>
					<p class="contact-note">
						For collaboration or roles, reference a concrete repo or problem—specific threads are easier to
						respond to than generic intros.
					</p>
				</section>
			</div>
		</main>
	</div>
</BaseLayout>
